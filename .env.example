# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit real secrets.

# Google Gemini API key — get a free one from https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Shared admin password for the /api/admin/auth endpoint (e.g. welcome123)
ADMIN_PASSWORD=

# Optional: secret used to sign admin JWTs. Defaults to "secret" if unset.
JWT_SECRET=

# Database (Postgres via docker-compose). Defaults match docker-compose.yml,
# so these are only needed to override them.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app
DB_USER=app
DB_PASSWORD=app
